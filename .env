#rename to .env so docker can read the enviroment variables

#DOMAIN
DOMAIN = rafaelhome.mourou.gr
#api
API_PORT = 80

#app
APP_PORT = 80

#mongo-express
MONGO_EXPRESS_PORT = 80

#mongo
DATABASE_ROOT_USER = root
DATABASE_ROOT_PASS = root
DATABASE_ROOT_DATABASE = admin
